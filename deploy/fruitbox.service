[Unit]
Description=Fruitbox game server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=fruitbox
Group=fruitbox
WorkingDirectory=/srv/fruitbox
Environment=NODE_ENV=production
ExecStart=/usr/bin/node server.js
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/srv/fruitbox/data

[Install]
WantedBy=multi-user.target
